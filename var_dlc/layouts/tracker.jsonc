                    {
                      "type": "group",
                      "header": "Abilities",
                      "dock": "left",
                      "margin": "0,0,3,0",
                      "content": {
                        "type": "layout",
                        "h_alignment": "center",
                        "v_alignment": "center",
                        "key": "Abilities"
                      }
                    }
                  ]
