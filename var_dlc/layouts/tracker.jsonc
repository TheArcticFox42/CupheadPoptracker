{
  //sets the trackers layout
  //more info: https://github.com/black-sliver/PopTracker/blob/master/doc/PACKS.md#layouts
  "tracker_default": {
    "type": "container",
    "background": "#877373",
    "content": {
      "type": "dock",
      "dropshadow": true,
      "content": [
        {
          "type": "dock",
          "background": "#212121",
          "item_h_alignment": "stretch",
          "content": [
            {
              "type": "layout",
              "key": "Tabbed Map"
            }
          ]
        },
        {
          "type": "dock",
          "dock": "bottom",
          "v_alignment": "stretch",
          "content": [
            {
              "type": "dock",
              "dock": "left",
              "content": [
                {
                  "type": "dock",
                  "dock": "top",
                  "content": [
                    {
                      "type": "group",
                      "header": "Weapons",
                      "dock": "left",
                      "margin": "0,0,3,0",
                      "content": {
                        "type": "layout",
                        "h_alignment": "center",
                        "v_alignment": "center",
                        "key": "Weapons"
                      }
                    }
                  ]
                },
                {
