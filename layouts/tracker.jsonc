                    "content": {
                      "type": "layout",
                      "h_alignment": "center",
                      "v_alignment": "center",
                      "key": "Charms"
                    }
                  }
                ]
              },
              {
                "type": "dock",
                "dock": "left",
                "content": [
                  {
                    "type": "group",
                    "header": "Abilities",
                    "dock": "left",
                    "margin": "0,0,3,0",
                    "content": {
                      "type": "layout",
                      "h_alignment": "center",
                      "v_alignment": "center",
                      "key": "Abilities"
                    }
                  }
                ]
              },
              {
                "type": "dock",
                "dock": "left",
                "content": [
                  {
                    "type": "group",
                    "header": "Info",
                    "dock": "left",
                    "margin": "0,0,3,0",
                    "content": {
                      "type": "layout",
                      "h_alignment": "center",
                      "v_alignment": "center",
                      "key": "Info"
                    }
                  }
                ]
              },
              {
                "type": "dock",
                "dock": "left",
                "content": [
                  {
                    "type": "group",
                    "header": "Goals",
                    "dock": "left",
                    "margin": "0,0,3,0",
                    "content": {
                      "type": "layout",
                      "h_alignment": "center",
